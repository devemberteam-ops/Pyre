# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing — NEVER commit. The repo's contributors and CI fall
# back to debug signing. Production builds inject these via secrets.
/android/key.properties
/android/app/upload-keystore.jks
/android/app/*.jks
/android/app/*.keystore
*.jks
*.keystore

# Prompt Lab (Wave CY.18.211) — generated reports + the gitignored local
# live-mode config (the user creates local.json from local.example.json in a
# later wave; it holds an API key and must NEVER be committed).
tool/prompt_lab/out/
tool/prompt_lab/local.json

# Per-platform Gradle/build outputs (the root /build/ above only covers the
# top-level Flutter build dir, not Android's Gradle output).
/android/build/
/android/.gradle/

# Release/ is the web-bundle mirror that build_all.ps1 produces — it's a copy
# of build/web, not source. Never commit it.
/Release/

# Private outreach / pitch kit — business-development drafts (unsent partner
# emails, pitch deck, identity-reveal strategy). Local-only; must NEVER ship in
# the public AGPL repo.
outreach/

# Internal/private working docs — local-only, must NEVER ship in the public AGPL
# repo: deploy + store-listing strategy, the internal launch/security checklist,
# and the superpowers working docs (specs / plans / brainstorms incl. the
# monetization/partnership strategy + the mega-audit reports). They stay on disk
# for reference; they just don't go into git / any future push.
DEPLOY.md
docs/LAUNCH_CHECKLIST.md
docs/superpowers/
# More internal planning / strategy / ideas docs — same rule (local-only, never
# ship publicly). Marketing/listing copy, the internal launch-announcement draft
# (incl. its "for us" posting notes), the internal feature inventory, design
# briefs, and the dated audit / live-test working reports.
docs/STORE_LISTING.md
docs/COMMUNITY.md
docs/FEATURE_INVENTORY.md
docs/ANNOUNCEMENT.md
docs/SMOKE_TEST.md
docs/scene-background-library-brief.md
docs/prompt-pipeline-audit-2026-05-31.md
docs/live-test-findings-2026-05-31.md
